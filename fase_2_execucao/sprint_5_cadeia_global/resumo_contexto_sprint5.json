{
    "sprint": 5,
    "titulo": "Cadeia Global: Da Floresta ao Mercado",
    "status": "PRONTO PARA EXECUÇÃO",
    "data_validacao": "2026-03-29",
    
    "objetivo_principal": "Cruzar dados de exportação de commodities com dados de desmatamento em nível estadual para responder à pergunta: 'Para onde vai a produção associada ao desmatamento?'",
    
    "perguntas_pesquisa": [
        "Quais as UFs com maior exportação de commodities associadas ao desmatamento?",
